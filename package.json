{
  "name": "app-v2-build2",
  "version": "1.0.1",
  "main": "index.tsx",
  "scripts": {
    "postinstall": "node scripts/patch-ble-advertiser-sdk.mjs",
    "start": "expo start --lan --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "start:tunnel": "expo start --tunnel --clear",
    "android:device": "expo start --android --tunnel",
    "typecheck": "tsc --noEmit",
    "apk:debug": "node scripts/gradle-apk.mjs debug",
    "apk:debug:demo": "node scripts/gradle-apk.mjs debug demo",
    "apk:release": "node scripts/gradle-apk.mjs release",
    "apk:release:demo": "node scripts/gradle-apk.mjs release demo",
    "prototype:parity:report": "node scripts/prototype-parity-report.mjs",
    "deploy:rules:powershell": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-rules-only.ps1",
    "deploy:rules:powershell:dry": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-rules-only.ps1 -DryRun",
    "deploy:full:powershell": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-functions-and-rules.ps1",
    "deploy:full:powershell:dry": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-functions-and-rules.ps1 -DryRun",
    "prototype:parity:report:powershell": "powershell -ExecutionPolicy Bypass -File ./scripts/run-two-phone-parity-report.ps1"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^2.1.0",
    "@react-native-community/slider": "5.0.1",
    "expo": "~54.0.33",
    "expo-av": "~16.0.8",
    "expo-camera": "^55.0.18",
    "expo-constants": "~18.0.13",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-location": "^55.1.9",
    "expo-navigation-bar": "~5.0.10",
    "expo-network": "^55.0.13",
    "expo-notifications": "~0.32.11",
    "expo-random": "^14.0.1",
    "expo-screen-capture": "^55.0.13",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-video-thumbnails": "~10.0.8",
    "firebase": "^11.10.0",
    "lottie-react-native": "~7.3.1",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-ble-advertiser": "^0.0.17",
    "react-native-ble-plx": "^3.5.1",
    "react-native-get-sms-android": "^2.1.0",
    "react-native-nfc-manager": "^3.17.2",
    "react-native-otp-verify": "^1.2.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "15.12.1",
    "react-native-view-shot": "4.0.3",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}

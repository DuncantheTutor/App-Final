# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local

# Firebase Android client config (download from Firebase console; see google-services.json.example)
android/app/google-services.json

# typescript
*.tsbuildinfo

# Firebase / tooling logs
firebase-debug.log
firestore-debug.log
ui-debug.log
backend/functions/firebase-debug.log

# iOS (generate with prebuild when needed)
/ios

# Android: commit android/ source; android/.gitignore excludes build/, .gradle, etc.
